## Copy this file to local.properties and fill in your values.
## local.properties is git-ignored and never committed.

# Android SDK path
sdk.dir=/path/to/your/Android/sdk

# Your deployed Cloudflare Worker URL (e.g. https://communication-coach-proxy.<name>.workers.dev)
WORKER_URL=https://your-worker.workers.dev

# Random secret shared between the app and your Cloudflare Worker
# Generate one with: openssl rand -hex 32
APP_TOKEN=your-app-token-here
